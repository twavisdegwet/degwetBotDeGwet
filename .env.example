# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_GUILD_ID=your_discord_guild_id_here

# Torrent Repository Configuration
MAM_ID=your_mam_session_cookie
MAM_USERNAME=your@email.com
MAM_PASSWORD=your_password
TORRENT_BASE_URL=https://www.myanonamouse.net

# Deluge Configuration
DELUGE_HOST=192.168.x.x
DELUGE_PORT=8112
DELUGE_URL=http://192.168.x.x:8112
DELUGE_RPC_URL=http://192.168.x.x:8112/json
DELUGE_PASSWORD=your_deluge_password

# Google Drive (Service Account)
# Paste the entire service account JSON as a single-line string (minify with: jq -c . service-account.json)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"your-sa@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id
GDRIVE_SHARABLE_LINK=https://drive.google.com/drive/folders/your_folder_id?usp=drive_link

# Send to Kindle (Gmail API via same service account)
# Bot email must be approved in Amazon Kindle's Personal Document Settings
KINDLE_BOT_EMAIL=bot@yourdomain.com
KINDLE_EMAIL_MAPPINGS={"YOUR_DISCORD_USER_ID":"yourname@kindle.com"}

# Download Directory
DOWNLOADS_DIRECTORY=/path/to/torrent/downloads

# Comic Images (for /askbible and related features)
COMIC_IMAGE_PATH=/path/to/comics

# Bot Display Name (shown in AI personality prompts)
BOT_DISPLAY_NAME=BookBot

# Ollama AI (Primary)
OLLAMA_PRIMARY_HOST=http://localhost:11434
OLLAMA_PRIMARY_MODEL=your_model_name
OLLAMA_PRIMARY_TYPE=ollama

# Ollama AI (Secondary/Failover)
OLLAMA_SECONDARY_HOST=http://localhost:11435
OLLAMA_SECONDARY_MODEL=your_model_name
OLLAMA_SECONDARY_TYPE=ollama
OLLAMA_APPEND_NOTHINK=false

# NVIDIA API (Optional - used before Ollama if configured)
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# NZB Downloader (for /getmusic and similar)
NZBHYDRA_URL=http://192.168.x.x:5076
NZBHYDRA_API_KEY=your_nzbhydra_api_key
SABNZBD_URL=http://192.168.x.x:8080
SABNZBD_API_KEY=your_sabnzbd_api_key

# Bluesky (Optional social posting)
BLUESKY_HANDLE=yourhandle.bsky.social
BLUESKY_PASSWORD=your_bluesky_password

# HTTP Server
HTTP_PORT=3000
NODE_ENV=development
