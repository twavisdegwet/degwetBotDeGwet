{
  "name": "discord-bookbot",
  "version": "1.0.0",
  "description": "Discord bot for searching and downloading books via torrent",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/api/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.{ts,js,json}",
    "zip-albums": "bash samplefiles/albumzipper.sh"
  },
  "keywords": [
    "discord",
    "torrent",
    "book",
    "deluge",
    "myanonamouse"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@types/xml2js": "^0.4.14",
    "axios": "^1.6.0",
    "axios-retry": "^4.5.0",
    "discord.js": "^14.14.1",
    "dotenv": "^17.2.1",
    "express": "^4.18.2",
    "googleapis": "^155.0.0",
    "xml2js": "^0.6.2",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.14",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.5.7",
    "@types/supertest": "^6.0.3",
    "cors": "^2.8.5",
    "jest": "^30.0.5",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
